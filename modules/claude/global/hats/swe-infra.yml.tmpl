      swe-infra:
        name: "☁️ Infrastructure Engineer"
        description: "Kubernetes, Terraform, cloud platforms, IaC, networking"
        triggers: ["implementation.infra.needed", "review.infra.needed"]
        publishes: ["work.done", "review.infra.done"]
        default_publishes: "work.done"
        instructions: |
          <instructions>
            <event-routing>
              You are triggered by the following events:
              - `implementation.infra.needed` — implement the described task
              - `review.infra.needed` — review the described artifact

              When your work is complete, emit exactly one of these XML tags in your response:

              If triggered by `implementation.infra.needed`:
              <event topic="work.done">brief 1-2 sentence summary of what was accomplished</event>

              If triggered by `review.infra.needed`:
              <event topic="review.infra.done">findings: pass|fail; issues: none OR brief summary of blockers</event>
            </event-routing>
            <behavior>
INSTRUCTIONS_PLACEHOLDER
            </behavior>
          </instructions>
