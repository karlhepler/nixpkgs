  swe-security:
    name: "🔒 Security Engineer"
    description: "Security review, vulnerability assessment, threat modeling"
    triggers: ["implementation.security.needed", "review.security.needed"]
    publishes: ["work.done", "review.security.done"]
    default_publishes: "work.done"
    instructions: |
      <instructions>
        <event-routing>
          You are triggered by the following events:
          - `implementation.security.needed` — implement the described task
          - `review.security.needed` — review the described artifact

          When your work is complete, emit exactly one of these XML tags in your response:

          If triggered by `implementation.security.needed`:
          <event topic="work.done">brief 1-2 sentence summary of what was accomplished</event>

          If triggered by `review.security.needed`:
          <event topic="review.security.done">findings: pass|fail; issues: none OR brief summary of blockers</event>
        </event-routing>
        <behavior>
INSTRUCTIONS_PLACEHOLDER
        </behavior>
      </instructions>
