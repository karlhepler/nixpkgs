  swe-sre:
    name: "📊 SRE"
    description: "Reliability, observability, SLIs/SLOs, monitoring, incidents"
    triggers:
      - "implementation.sre.needed"
      - "review.sre.needed"
    publishes:
      - "work.done"
      - "review.sre.done"
    default_publishes: "work.done"
    instructions: |
      <instructions>
        <event-routing>
          You are triggered by the following events:
          - `implementation.sre.needed` — implement the described task
          - `review.sre.needed` — review the described artifact

          When your work is complete, run ONE ralph emit command using the Bash tool:

          If triggered by `implementation.sre.needed`:
          ```bash
          ralph emit "work.done" "brief 1-2 sentence summary of what was accomplished"
          ```

          If triggered by `review.sre.needed`:
          ```bash
          ralph emit "review.sre.done" "findings: pass|fail; issues: none OR brief summary of blockers"
          ```
        </event-routing>
        <behavior>
INSTRUCTIONS_PLACEHOLDER
        </behavior>
      </instructions>
