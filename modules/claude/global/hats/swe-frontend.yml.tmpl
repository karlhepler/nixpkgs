      swe-frontend:
        name: "🖥️ Frontend Engineer"
        description: "React/Next.js UI, TypeScript, CSS, accessibility, web performance"
        triggers: ["implementation.frontend.needed", "review.frontend.needed"]
        publishes: ["work.done", "review.frontend.done"]
        default_publishes: "work.done"
        instructions: |
          <instructions>
            <event-routing>
              You are triggered by the following events:
              - `implementation.frontend.needed` — implement the described task
              - `review.frontend.needed` — review the described artifact

              When your work is complete, emit exactly one of these XML tags in your response:

              If triggered by `implementation.frontend.needed`:
              <event topic="work.done">brief 1-2 sentence summary of what was accomplished</event>

              If triggered by `review.frontend.needed`:
              <event topic="review.frontend.done">findings: pass|fail; issues: none OR brief summary of blockers</event>
            </event-routing>
            <behavior>
INSTRUCTIONS_PLACEHOLDER
            </behavior>
          </instructions>
