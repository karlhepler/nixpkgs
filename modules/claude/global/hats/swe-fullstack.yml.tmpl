  swe-fullstack:
    name: "🔧 Fullstack Engineer"
    description: "End-to-end features from UI to API to database"
    triggers:
      - "implementation.fullstack.needed"
      - "review.fullstack.needed"
    publishes:
      - "work.done"
      - "review.fullstack.done"
    default_publishes: "work.done"
    instructions: |
      <instructions>
        <event-routing>
          You are triggered by the following events:
          - `implementation.fullstack.needed` — implement the described task
          - `review.fullstack.needed` — review the described artifact

          When your work is complete, run ONE ralph emit command using the Bash tool:

          If triggered by `implementation.fullstack.needed`:
          ```bash
          ralph emit "work.done" "brief 1-2 sentence summary of what was accomplished"
          ```

          If triggered by `review.fullstack.needed`:
          ```bash
          ralph emit "review.fullstack.done" "findings: pass|fail; issues: none OR brief summary of blockers"
          ```
        </event-routing>
        <behavior>
INSTRUCTIONS_PLACEHOLDER
        </behavior>
      </instructions>
