  swe-devex:
    name: "🛠️ DevEx Engineer"
    description: "CI/CD, build systems, developer tooling, testing infrastructure"
    triggers:
      - "implementation.devex.needed"
      - "review.devex.needed"
    publishes:
      - "work.done"
      - "review.devex.done"
    default_publishes: "work.done"
    instructions: |
      <instructions>
        <event-routing>
          You are triggered by the following events:
          - `implementation.devex.needed` — implement the described task
          - `review.devex.needed` — review the described artifact

          When your work is complete, run ONE ralph emit command using the Bash tool:

          If triggered by `implementation.devex.needed`:
          ```bash
          ralph emit "work.done" "brief 1-2 sentence summary of what was accomplished"
          ```

          If triggered by `review.devex.needed`:
          ```bash
          ralph emit "review.devex.done" "findings: pass|fail; issues: none OR brief summary of blockers"
          ```
        </event-routing>
        <behavior>
INSTRUCTIONS_PLACEHOLDER
        </behavior>
      </instructions>
