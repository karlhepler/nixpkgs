  swe-devex:
    name: "🛠️ DevEx Engineer"
    description: "CI/CD, build systems, developer tooling, testing infrastructure"
    triggers: ["implementation.devex.needed", "review.devex.needed"]
    publishes: ["work.done", "review.devex.done"]
    default_publishes: "work.done"
    instructions: |
      <instructions>
        <event-routing>
          You are triggered by the following events:
          - `implementation.devex.needed` — implement the described task
          - `review.devex.needed` — review the described artifact

          When your work is complete, emit exactly one of these XML tags in your response:

          If triggered by `implementation.devex.needed`:
          <event topic="work.done">brief 1-2 sentence summary of what was accomplished</event>

          If triggered by `review.devex.needed`:
          <event topic="review.devex.done">findings: pass|fail; issues: none OR brief summary of blockers</event>
        </event-routing>
        <behavior>
INSTRUCTIONS_PLACEHOLDER
        </behavior>
      </instructions>
