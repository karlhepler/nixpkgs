  swe-backend:
    name: "⚙️ Backend Engineer"
    description: "Backend APIs, databases, server-side logic, data modeling"
    triggers:
      - "implementation.backend.needed"
      - "review.backend.needed"
    publishes:
      - "work.done"
      - "review.backend.done"
    default_publishes: "work.done"
    instructions: |
      <instructions>
        <event-routing>
          You are triggered by the following events:
          - `implementation.backend.needed` — implement the described task
          - `review.backend.needed` — review the described artifact

          When your work is complete, run ONE ralph emit command using the Bash tool:

          If triggered by `implementation.backend.needed`:
          ```bash
          ralph emit "work.done" "brief 1-2 sentence summary of what was accomplished"
          ```

          If triggered by `review.backend.needed`:
          ```bash
          ralph emit "review.backend.done" "findings: pass|fail; issues: none OR brief summary of blockers"
          ```
        </event-routing>
        <behavior>
INSTRUCTIONS_PLACEHOLDER
        </behavior>
      </instructions>
