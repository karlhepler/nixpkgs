#compdef kanban

# Zsh completion for kanban CLI (v2 — JSON-based cards)
# Provides tab completion for subcommands, card numbers, flags, and criteria subcommands

_kanban() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  # Get kanban root directory using same logic as CLI
  local kanban_root
  if [[ -n "$KANBAN_ROOT" ]]; then
    kanban_root="$KANBAN_ROOT"
  else
    local git_root
    git_root=$(git rev-parse --show-toplevel 2>/dev/null)
    if [[ -n "$git_root" ]]; then
      kanban_root="$git_root/.kanban"
    else
      kanban_root="$PWD/.kanban"
    fi
  fi

  # Function to get card numbers from all columns
  _kanban_cards() {
    local -a cards
    if [[ -d "$kanban_root" ]]; then
      for col in todo doing review done canceled; do
        local col_path="$kanban_root/$col"
        if [[ -d "$col_path" ]]; then
          for card in "$col_path"/*.json(N); do
            local card_num=${${card:t}%.json}
            cards+=("$card_num:card in $col")
          done
        fi
      done
    fi
    _describe -t cards 'card number' cards
  }

  # Common session flags
  _kanban_session_flags=(
    '--session[Filter by session ID]:session:'
    '--only-mine[Show only current session cards]'
    '--show-mine[Show mine (override KANBAN_HIDE_MINE)]'
    '--hide-mine[Hide current session cards]'
  )

  # Main command specification
  _arguments -C \
    '--root[Kanban root directory]:directory:_directories' \
    '1: :->command' \
    '*:: :->args'

  case $state in
    command)
      local -a commands
      commands=(
        'init:Create kanban board structure'
        'session-hook:Handle SessionStart hook (reads JSON from stdin)'
        'do:Create card(s) in doing from JSON'
        'todo:Create card(s) in todo from JSON'
        'show:Display card contents'
        'start:Move card(s) from todo to doing'
        'review:Move card(s) to review'
        'done:Move card to done with summary'
        'redo:Move card from review back to doing'
        'defer:Move card(s) from doing/review to todo'
        'cancel:Move card(s) to canceled'
        'comment:Add timestamped comment to card'
        'criteria:Manage acceptance criteria'
        'ac:Manage acceptance criteria (alias for criteria)'
        'list:Show board overview'
        'ls:Show board overview (alias for list)'
        'report:Generate reporting from completed cards'
        'clean:Delete cards with user confirmation'
      )
      _describe -t commands 'kanban command' commands
      ;;
    args)
      case $line[1] in
        init)
          _arguments \
            '1::path:_directories' \
            '--watch[Auto-refresh on changes]' \
            ${_kanban_session_flags[@]}
          ;;
        session-hook)
          _arguments \
            '--watch[Auto-refresh on changes]' \
            ${_kanban_session_flags[@]}
          ;;
        do|todo)
          _arguments \
            '1:json_data:' \
            '--watch[Auto-refresh on changes]' \
            ${_kanban_session_flags[@]}
          ;;
        show)
          _arguments \
            '1:card:_kanban_cards' \
            '--output-style[Output format]:style:(simple xml detail)' \
            '--watch[Auto-refresh on changes]' \
            ${_kanban_session_flags[@]}
          ;;
        start|defer|cancel|review)
          _arguments \
            '*:card:_kanban_cards' \
            '--watch[Auto-refresh on changes]' \
            ${_kanban_session_flags[@]}
          ;;
        cancel)
          _arguments \
            '*:card:_kanban_cards' \
            '--reason[Cancellation reason]:reason:' \
            '--watch[Auto-refresh on changes]' \
            ${_kanban_session_flags[@]}
          ;;
        redo)
          _arguments \
            '1:card:_kanban_cards' \
            '--watch[Auto-refresh on changes]' \
            ${_kanban_session_flags[@]}
          ;;
        done)
          _arguments \
            '1:card:_kanban_cards' \
            '2::message:' \
            '--watch[Auto-refresh on changes]' \
            ${_kanban_session_flags[@]}
          ;;
        comment)
          _arguments \
            '1:card:_kanban_cards' \
            '2:text:' \
            '--watch[Auto-refresh on changes]' \
            ${_kanban_session_flags[@]}
          ;;
        list|ls)
          _arguments \
            '--column[Filter column(s)]:column:(todo doing review done canceled)' \
            '--show-done[Include done column]' \
            '--show-canceled[Include canceled column]' \
            '--show-all[Include done and canceled columns]' \
            '--output-style[Output format]:style:(simple xml detail)' \
            '--since[Filter by date]:date:(today yesterday week month)' \
            '--until[Filter until date]:date:' \
            '--watch[Auto-refresh on changes]' \
            ${_kanban_session_flags[@]}
          ;;
        report)
          _arguments \
            '--from[Start date (YYYY-MM-DD)]:date:' \
            '--to[End date (YYYY-MM-DD)]:date:' \
            '--output-style[Output format]:style:(human xml)' \
            '--watch[Auto-refresh on changes]'
          ;;
        clean)
          _arguments \
            '1::column:(todo doing review done canceled)' \
            '--expunge[Also delete scratchpad contents]' \
            '--watch[Auto-refresh on changes]'
          ;;
        criteria|ac)
          # Handle criteria subcommands
          if (( CURRENT == 2 )); then
            local -a subcommands
            subcommands=(
              'add:Add acceptance criterion'
              'remove:Remove acceptance criterion'
              'check:Mark criterion as met (agent_met)'
              'uncheck:Mark criterion as unmet (clears agent_met)'
              'verify:Mark criterion as reviewer-verified (reviewer_met)'
              'unverify:Clear reviewer verification (clears reviewer_met)'
            )
            _describe -t subcommands 'criteria subcommand' subcommands
          else
            local subcmd="$line[2]"
            case $subcmd in
              add)
                _arguments \
                  '2:card:_kanban_cards' \
                  '3:text:' \
                  '--watch[Auto-refresh on changes]' \
                  ${_kanban_session_flags[@]}
                ;;
              remove)
                _arguments \
                  '2:card:_kanban_cards' \
                  '3:criterion number:' \
                  '4:reason:' \
                  '--watch[Auto-refresh on changes]' \
                  ${_kanban_session_flags[@]}
                ;;
              check|uncheck|verify|unverify)
                _arguments \
                  '2:card:_kanban_cards' \
                  '*:criterion indices:' \
                  '--watch[Auto-refresh on changes]' \
                  ${_kanban_session_flags[@]}
                ;;
            esac
          fi
          ;;
      esac
      ;;
  esac
}

_kanban "$@"
