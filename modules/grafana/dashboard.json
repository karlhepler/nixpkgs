            "matcher": { "id": "byName", "options": "total_turns" },
            "properties": [
              { "id": "displayName", "value": "Turns" },
              { "id": "custom.width", "value": 70 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "total_tokens" },
