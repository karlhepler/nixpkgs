          "rawSql": "SELECT session_id, COALESCE(kanban_session, '') as kanban, working_directory as project, COUNT(*) as agents, SUM(turns) as total_turns, SUM(input_tokens + output_tokens) as total_tokens, ROUND(SUM(cost_usd), 4) as total_cost FROM agent_metrics GROUP BY session_id ORDER BY total_cost DESC LIMIT 10",
